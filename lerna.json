{
  "$schema": "./node_modules/@lerna-lite/cli/schemas/lerna-schema.json",
  "version": "independent",
  "npmClient": "pnpm",

  "conventionalCommits": true,
  "changelogPreset": "conventional-changelog-conventionalcommits",
  "exact": true,

  "command": {
    "publish": {
      "cleanupTempFiles": true,
      "stripPackageKeys": ["devDependencies", "scripts"]
    }
  },

  "ignoreChanges": [
    "*.md",
    "**/test/**",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "turbo.json",
    "eslint.config.js",
    "tsconfig.json",
    "typedoc*.json*",
    "local-ci.sh",
    "scripts/**",
    "starter-projects/**"
  ],

  "packages": [
    "./packages/gracile",

    "./packages/client",
    "./packages/server",
    "./packages/engine",

    "./packages/create-gracile",

    "./packages/internal/tsconfigs",
    "./packages/internal/utils",
    "./packages/internal/test-utils",

    "./packages/addons/metadata",
    "./packages/addons/svg",
    "./packages/addons/sitemap",
    "./packages/addons/markdown",
    "./packages/addons/markdown-preset-marked",
    "./packages/labs/better-errors",
    "./packages/labs/client-router",
    "./packages/labs/css-helpers",
    "./packages/labs/hmr",
    "./packages/labs/babel-plugin-jsx-to-literals",
    "./packages/labs/functional",
    "./packages/labs/vite-plugin-babel-jsx-to-literals",
    "./packages/labs/islands",
    "./packages/labs/jsx-forge",
    "./packages/labs/og-images-generator",
    "./packages/labs/vite-plugin-jsx-forge",
    "./packages/labs/vite-plugin-standard-css-modules",
    "./packages/labs/literals/parser",
    "./packages/labs/literals/html-css-minifier",
    "./packages/labs/literals/rollup-plugin-html-css-minifier",

    "./docs/website"
  ]
}
