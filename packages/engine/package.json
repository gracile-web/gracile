{
  "name": "@gracile/engine",
  "version": "0.9.0-next.1",
  "description": "A thin, full-stack, web framework",
  "keywords": [
    "custom-elements",
    "full-stack",
    "lit",
    "meta-framework",
    "server",
    "server-side-rendering",
    "ssr",
    "static",
    "web-components"
  ],
  "homepage": "https://gracile.js.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/gracile-web/gracile",
    "directory": "packages/engine"
  },
  "license": "ISC",
  "author": {
    "name": "Julian Cataldo",
    "email": "contact@juliancataldo.com",
    "url": "https://www.juliancataldo.com"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./ambient": "./ambient.d.ts",
    "./server/*": {
      "types": "./dist/server/*.js",
      "development": "./dist/server/*.js",
      "default": "./dist/server/*.js"
    }
  },
  "files": [
    "./ambient.d.ts",
    "./dist/**/*",
    "!/dist/**/*.test.*",
    "!/dist/typedoc-entrypoint.*"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf ./dist",
    "dev": "tsc --watch",
    "test:unit": "c8 node --test --enable-source-maps 'dist/**/*.test.js'",
    "test:unit:dev": "node --test --enable-source-maps --watch 'dist/**/*.test.js'"
  },
  "dependencies": {
    "@gracile-labs/better-errors": "workspace:^",
    "@gracile/internal-utils": "workspace:^",
    "@whatwg-node/server": "^0.10.18",
    "fdir": "^6.5.0",
    "picocolors": "catalog:",
    "urlpattern-polyfill": "catalog:",
    "vite": "catalog:"
  },
  "devDependencies": {
    "@gracile/internal-tsconfigs": "workspace:^",
    "@types/express": "5.0.6",
    "@types/node": "^25.3.3",
    "c8": "^11.0.0",
    "sinon": "21.0.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@lit-labs/ssr": "catalog:",
    "@lit-labs/ssr-client": "catalog:",
    "lit": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
