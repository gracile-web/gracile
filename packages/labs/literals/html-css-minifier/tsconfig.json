{
  "compilerOptions": {
    "declaration": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2023",
    "outDir": "dist",

    "declarationMap": true,

    "rootDir": "src",

    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
