{
  "name": "@gracile-labs/islands",
  "version": "0.2.2",
  "description": "Islands architecture add-on for Gracile — SSR and hydrate components from any framework",
  "keywords": [
    "custom-elements",
    "full-stack",
    "lit",
    "meta-framework",
    "server",
    "server-side-rendering",
    "ssr",
    "static",
    "web-components",
    "islands",
    "hydration",
    "react",
    "vue",
    "svelte",
    "solid",
    "preact"
  ],
  "homepage": "https://gracile.js.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/gracile-web/gracile",
    "directory": "packages/labs/islands"
  },
  "license": "ISC",
  "author": {
    "name": "Julian Cataldo",
    "email": "contact@juliancataldo.com",
    "url": "https://www.juliancataldo.com"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./*/define": {
      "types": "./dist/*/define.client.js",
      "browser": "./dist/*/define.client.js",
      "node": "./dist/*/define.server.js"
    },
    "./define": "./dist/define.js",
    "./client": "./dist/client.js"
  },
  "files": [
    "./dist/**/*",
    "!/dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf ./dist",
    "dev": "tsc --watch",
    "test:integration": "tsx --test-concurrency=1 --test -C test 'test/integration/**/*.test.ts'",
    "test:unit": "c8 node --test --enable-source-maps 'dist/**/*.test.js'",
    "test:unit:dev": "node --test --enable-source-maps --watch 'dist/**/*.test.js'"
  },
  "dependencies": {
    "@gracile/internal-utils": "workspace:^",
    "@lit-labs/ssr": "catalog:",
    "@lit-labs/ssr-client": "catalog:",
    "lit": "catalog:"
  },
  "devDependencies": {
    "@gracile/internal-test-utils": "workspace:^",
    "@gracile/internal-tsconfigs": "workspace:^",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "preact": "catalog:",
    "preact-render-to-string": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "solid-js": "catalog:",
    "svelte": "catalog:",
    "vite": "^7.0.0 || ^8.0.0",
    "vue": "catalog:"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": true
    },
    "preact-render-to-string": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
