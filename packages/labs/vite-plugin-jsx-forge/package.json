{
  "name": "@gracile-labs/vite-plugin-jsx-forge",
  "version": "0.2.1-next.0",
  "description": "A thin, full-stack, web framework",
  "keywords": [
    "custom-elements",
    "full-stack",
    "lit",
    "meta-framework",
    "server",
    "server-side-rendering",
    "ssr",
    "static",
    "web-components"
  ],
  "homepage": "https://gracile.js.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/gracile-web/gracile",
    "directory": "packages/labs/vite-plugin-jsx-forge"
  },
  "license": "ISC",
  "author": {
    "name": "Julian Cataldo",
    "email": "contact@juliancataldo.com",
    "url": "https://www.juliancataldo.com"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./ambient": "./ambient.d.ts"
  },
  "files": [
    "./ambient.d.ts",
    "./dist/**/*",
    "!/dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf ./dist",
    "dev": "tsc --watch",
    "test:integration": "tsx --test-concurrency=1 --test -C test 'test/integration/**/*.test.ts'"
  },
  "dependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "jsx-forge": "workspace:^",
    "ts-patch": "^3.3.0"
  },
  "devDependencies": {
    "@gracile/internal-test-utils": "workspace:^",
    "@gracile/internal-tsconfigs": "workspace:^",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@lit-labs/ssr": "^3.2.2",
    "clsx": "^2.1.1",
    "jsx-forge": "workspace:^",
    "lit": "^3.3.0",
    "vite": "^6.2.5"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
