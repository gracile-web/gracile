{
  "name": "@gracile-labs/better-errors",
  "version": "0.4.3",
  "description": "A thin, full-stack, web framework",
  "keywords": [
    "vite",
    "custom-elements",
    "full-stack",
    "lit",
    "meta-framework",
    "server",
