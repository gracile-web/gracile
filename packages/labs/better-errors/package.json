    "./ambient.d.ts",
    "./dist/**/*",
    "!/dist/**/*.test.*",
    "!/dist/typedoc-entrypoint.*"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf ./dist",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@gracile/internal-utils": "workspace:^",
    "picocolors": "catalog:",
    "shiki": "catalog:"
  },
  "devDependencies": {
    "@gracile/internal-tsconfigs": "workspace:^",
    "@literals/html-css-minifier": "workspace:^",
    "@literals/rollup-plugin-html-css-minifier": "workspace:^",
    "@rollup/plugin-terser": "^0.4.4",
    "terser": "^5.46.0",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "vite": "^7.0.0 || ^8.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
