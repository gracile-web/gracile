{
  "name": "jsx-forge",
  "webElements": {
    "format": "jsx",
    "jsxBootstrapPath": "./jsx-bootstrap.ts",
    "conventions": {
      "bareBindingKind": "attribute",
      "attributes": {
        "namespaces": [
          null,
          "bool",
          "if"
        ]
      },
      "events": {
        "namespaces": [
          "on"
        ]
      },
      "properties": {
        "namespaces": [
          "_"
        ]
      }
    }
  },
  "version": "0.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": {
    "name": "Julian Cataldo",
    "email": "contact@juliancataldo.com",
    "url": "https://www.juliancataldo.com"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./transform": "./dist/ts-patch-transformer-plugin.js",
    "./package.json": "./package.json",
    "./jsx-runtime": "./dist/jsx-namespace.d.ts",
    "./lit-compiler": "./dist/lit-compiler-ts-patch-plugin.js"
  },
  "files": [
    "./dist/**/*",
    "!/dist/**/*.test.*",
    "!/dist/tests",
    "!dist/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf ./dist",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "csstype": "^3.1.3"
  },
  "devDependencies": {
    "@gracile/internal-tsconfigs": "workspace:^",
    "ts-patch": "^3.3.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "@lit-labs/compiler": "^1.1.2"
  },
  "peerDependencies": {
    "typescript": ">=5",
    "@lit-labs/compiler": "^1.1.2"
  },
  "peerDependenciesMeta": {
    "@lit-labs/compiler": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
