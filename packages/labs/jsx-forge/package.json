{
  "name": "jsx-forge",
  "version": "0.3.0",
  "description": "",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/gracile-web/gracile",
    "directory": "packages/labs/jsx-forge"
  },
  "license": "ISC",
  "author": {
    "name": "Julian Cataldo",
    "email": "contact@juliancataldo.com",
    "url": "https://www.juliancataldo.com"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./transform": "./dist/ts-patch-transformer-plugin.js",
    "./to-literals": "./dist/to-literals/to-literals.js",
    "./presets/lit": "./dist/presets/lit.js",
    "./types": "./dist/types.js",
    "./package.json": "./package.json",
    "./jsx-runtime": "./dist/jsx-namespace.d.ts",
    "./lit-compiler": "./dist/lit-compiler-ts-patch-plugin.js"
  },
  "files": [
    "./dist/**/*",
    "!/dist/**/*.test.*",
    "!/dist/tests",
    "!dist/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf ./dist",
    "dev": "tsc --watch",
    "test:integration": "tsx --test-concurrency=1 --test -C test 'test/integration/**/*.test.ts'"
  },
  "dependencies": {
    "csstype": "^3.1.3"
  },
  "devDependencies": {
    "@gracile/internal-test-utils": "workspace:^",
    "@gracile/internal-tsconfigs": "workspace:^",
    "@lit-labs/compiler": "^1.1.2",
    "ts-patch": "^3.3.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@lit-labs/compiler": "^1.1.2",
    "ts-patch": "^3.3.0",
    "typescript": ">=5"
  },
  "peerDependenciesMeta": {
    "@lit-labs/compiler": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "webElements": {
    "format": "jsx",
    "jsxBootstrapPath": "./jsx-bootstrap.ts",
    "conventions": {
      "bareBindingKind": "attribute",
      "attributes": {
        "namespaces": [
          null,
          "bool",
          "if"
        ]
      },
      "events": {
        "namespaces": [
          "on"
        ]
      },
      "properties": {
        "namespaces": [
          "_"
        ]
      }
    }
  }
}
