{
  "name": "@gracile/client",
  "version": "0.5.0-next.5",
  "description": "A thin, full-stack, web framework",
  "keywords": [
    "custom-elements",
    "full-stack",
    "lit",
    "meta-framework",
    "server",
    "server-side-rendering",
    "ssr",
    "static",
    "web-components"
  ],
  "homepage": "https://gracile.js.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/gracile-web/gracile",
    "directory": "packages/client"
  },
  "license": "ISC",
  "author": {
    "name": "Julian Cataldo",
    "email": "contact@juliancataldo.com",
    "url": "https://www.juliancataldo.com"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "files": [
    "./dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf ./dist",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@gracile/engine": "workspace:^",
    "@gracile/internal-utils": "workspace:^",
    "@lit-labs/ssr": "catalog:",
    "@lit-labs/ssr-client": "catalog:",
    "urlpattern-polyfill": "catalog:"
  },
  "peerDependencies": {
    "@lit-labs/signals": "^0.1.1"
  },
  "peerDependenciesMeta": {
    "@lit-labs/signals": {
      "optional": true
    }
  },
  "devDependencies": {
    "@gracile/internal-tsconfigs": "workspace:^",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "// disabledDeps": {
    "@webcomponents/template-shadowroot": "0.x",
    "typedoc": "^0.25.8"
  }
}
