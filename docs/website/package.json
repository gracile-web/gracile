{
  "name": "@gracile/docs",
  "version": "0.12.0",
  "private": true,
  "license": "ISC",
  "author": {
    "name": "Julian Cataldo"
  },
  "type": "module",
  "imports": {
    "#/*": "./app/*"
  },
  "exports": {
    "./*": "./*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "// build": "node ./node_modules/@gracile/gracile/dist/cli.js build",
    "// build:client": "vite build --outDir dist/client",
    "// build:server": "vite build --outDir dist/server --ssr src/entry-server.ts ",
    "// dev": "node --experimental-vm-modules --watch-path server server/server.js",
    "// preview:client": "vite preview",
    "// serve": "cross-env NODE_ENV=production node server/server.js",
    "prebuild": "node --run docs:generate",
    "build": "vite build",
    "postbuild": "node --run pagefind",
    "check:links": "linkinator --config linkinator.config.json . > linkinator-result.json",
    "clean": "rm -rf ./dist",
    "deploy": "netlify deploy -d ./dist",
    "deploy:main": "netlify deploy -d ./docs/website/dist --prod --no-build",
    "deploy:next": "netlify deploy -d ./docs/website/dist --alias next --no-build",
    "dev": "vite dev",
    "docs:generate": "tsx scripts/collect-readmes.ts && tsx scripts/collect-typedocs.ts",
    "pagefind": "npx pagefind -s dist --output-path dist/pagefind --exclude-selectors '[hidden]' && cp -r dist/pagefind public",
    "preview": "vite preview",
    "release": "npm run build && npm run pagefind && npm run deploy",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "test:smoke:ui": "playwright test --ui"
  },
  "overrides": {
    "@types/react": "npm:types-react@rc",
    "lit": "^3.3.0"
  },
