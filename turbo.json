{
  "$schema": "https://turbo.build/schema.json",

  "tasks": {
    "dev": {
      "outputs": ["dist/**"],

      "cache": false,
      "persistent": true
    },
    "clean": {
      "outputs": ["dist/**"],
      "cache": false
      // "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "test:unit": {
      "cache": false,
      "persistent": true
    },
    "test:unit:dev": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "check:types": {
      "dependsOn": ["^build"]
    }
  }
}
