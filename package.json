{
  "name": "@gracile/root",
  "version": "0.0.0",
  "private": true,
  "description": "A thin, full-stack, web framework",
  "keywords": [
    "custom-elements",
    "full-stack",
    "lit",
    "server",
    "server-side-rendering",
    "ssr",
    "static",
    "web-components"
  ],
  "homepage": "https://gracile.js.org",
  "repository": "gracile-web/gracile",
  "license": "ISC",
  "author": {
    "name": "Julian Cataldo",
    "email": "contact@juliancataldo.com",
    "url": "https://www.juliancataldo.com"
  },
  "type": "module",
  "scripts": {
    "audit": "pnpm audit signatures --prod",
    "build": "node --run build:libs",
    "build:docs": "pnpm --filter @gracile/docs build",
    "build:libs": "NODE_OPTIONS=--max-old-space-size=8192 turbo build --filter=!@gracile/docs --filter=!@gracile/starter-projects --filter=!@gracile/template--* --filter=!@gracile/demo--* --filter=!@gracile-labs/demo--* --filter=!@literals/demo--* --concurrency 34",
    "check-all": "pnpm build && (pnpm test:unit & pnpm test:integration & pnpm lint:es & pnpm format)",
    "clean": "turbo clean --filter=!@gracile/starter-projects --filter=!@gracile/template--* --filter=!@gracile/demo--* --filter=!@gracile-labs/demo--* --filter=!@literals/demo--* --concurrency 34",
    "dev": "node --run dev:libs",
    "dev:docs": "pnpm --filter @gracile/docs dev",
    "dev:libs": "turbo dev --filter=!@gracile/docs --filter=!@gracile/starter-projects --filter=!@gracile/template--* --filter=!@gracile/demo--* --filter=!@gracile-labs/demo--* --filter=!@literals/demo--* --concurrency 34",
    "docs:generate": "typedoc",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "preinstall": "npx only-allow pnpm",
    "knip": "knip",
    "lint:commit": "commitlint --from=HEAD~1",
    "lint:css": "stylelint '**/*.{css,scss}' --ignore-path .gitignore",
    "lint:css:fix": "stylelint '**/*.{css,scss}' --ignore-path .gitignore --fix",
    "lint:es": "eslint --cache .",
    "lint:es:fix": "eslint --cache --fix .",
    "list-pkg": "pnpm m ls --json --depth=-1 | node -e \"const path = require('path'); console.log(JSON.parse(require('fs').readFileSync('/dev/stdin', 'utf-8')).map((m) => path.relative(__dirname, m.path)).filter(Boolean))\" # From https://github.com/pnpm/pnpm/issues/1519",
    "nolyfill": "pnpm dlx nolyfill install",
    "postnolyfill": "pnpm install",
    "prepare": "husky",
    "sort-pjson": "pnpm sort-package-json '**/package.json'",
    "test:integration": "turbo test:integration --filter=!@gracile/starter-projects --filter=!@gracile/template--* --filter=!@gracile/demo--* --filter=!@gracile-labs/demo--* --filter=!@literals/demo--* --continue --concurrency 1",
    "test:unit": "turbo test:unit --filter=!@gracile/starter-projects --filter=!@gracile/template--* --filter=!@gracile/demo--* --filter=!@gracile-labs/demo--* --filter=!@literals/demo--* --concurrency 34",
    "test:unit:dev": "FORCE_COLOR=1 pnpm -r --parallel --filter=!@gracile/starter-projects --filter=!@gracile/template--* --filter=!@gracile/demo--* --filter=!@gracile-labs/demo--* --filter=!@literals/demo--* test:unit:dev"
  },
  "resolutions": {
    "braces": "3.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^9.39.3",
    "@eslint/markdown": "^7.5.1",
    "@lerna-lite/cli": "^4.11.5",
    "@lerna-lite/list": "^4.11.5",
    "@lerna-lite/publish": "^4.11.5",
    "@types/node": "25.3.3",
    "c8": "11.0.0",
    "concurrently": "^9.2.1",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-markdown-frontmatter-schema": "^0.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "knip": "^6.0.1",
    "prettier": "^3.8.1",
    "sort-package-json": "^3.6.1",
    "stylelint": "^16.10.0",
    "stylelint-config-recess-order": "^5.1.1",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-order": "^6.0.4",
    "tsx": "^4.21.0",
    "turbo": "^2.8.12",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "auditConfig": {
      "ignoreCves": []
    },
    "overrides": {
      "@eslint/plugin-kit": "npm:@eslint/plugin-kit@^0.3.4",
      "@types/node": "25.3.3",
      "array-includes": "npm:@nolyfill/array-includes@^1",
      "array.prototype.findlast": "npm:@nolyfill/array.prototype.findlast@^1",
      "array.prototype.findlastindex": "npm:@nolyfill/array.prototype.findlastindex@^1",
      "array.prototype.flat": "npm:@nolyfill/array.prototype.flat@^1",
      "array.prototype.flatmap": "npm:@nolyfill/array.prototype.flatmap@^1",
      "array.prototype.tosorted": "npm:@nolyfill/array.prototype.tosorted@^1",
      "cross-spawn": "npm:cross-spawn@^7.0.6",
      "devalue": ">=5.6.4",
      "es-iterator-helpers": "npm:@nolyfill/es-iterator-helpers@^1",
      "flatted": ">=3.4.2",
      "h3": ">=1.15.9",
      "hasown": "npm:@nolyfill/hasown@^1",
      "hono": ">=4.12.7",
      "immutable": ">=4.3.8",
      "is-core-module": "npm:@nolyfill/is-core-module@^1",
      "isarray": "npm:@nolyfill/isarray@^1",
      "nanoid": "npm:nanoid@^3.3.8",
      "object-keys": "npm:@nolyfill/object-keys@^1",
      "object.assign": "npm:@nolyfill/object.assign@^1",
      "object.entries": "npm:@nolyfill/object.entries@^1",
      "object.fromentries": "npm:@nolyfill/object.fromentries@^1",
      "object.groupby": "npm:@nolyfill/object.groupby@^1",
      "object.values": "npm:@nolyfill/object.values@^1",
      "safer-buffer": "npm:@nolyfill/safer-buffer@^1",
      "side-channel": "npm:@nolyfill/side-channel@^1",
      "smol-toml": ">=1.6.1",
      "string.prototype.codepointat": "npm:@nolyfill/string.prototype.codepointat@^1",
      "string.prototype.matchall": "npm:@nolyfill/string.prototype.matchall@^1",
      "string.prototype.repeat": "npm:@nolyfill/string.prototype.repeat@^1",
      "tar": ">=7.5.11",
      "undici": "^7.24.0",
      "safe-buffer": "npm:@nolyfill/safe-buffer@^1",
      "handlebars": ">=4.7.9",
      "node-forge": ">=1.4.0",
      "path-to-regexp": ">=8.4.0",
      "fastify": ">=5.8.3",
      "picomatch": ">=4.0.4",
      "serialize-javascript": ">=7.0.5",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "brace-expansion@<1.1.13": "1.1.13"
    }
  }
}
